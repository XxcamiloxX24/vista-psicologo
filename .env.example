# La API debe devolver refreshToken en el login y exponer POST /api/Autenticacion/refrescar.
# La app renueva el JWT sola (localStorage: healthymind_refresh_token).

# URL base de la API (opcional)
# Por defecto: http://healthymind10.runasp.net
# Para producción en Netlify con API en HTTPS, usa: https://healthymind10.runasp.net
VITE_API_URL=http://healthymind10.runasp.net

# URL de la API de Chat (Socket.io + REST)
# Desarrollo: http://localhost:3000
# Producción: https://chat-healthy-mind.onrender.com
VITE_CHAT_API_URL=https://chat-healthy-mind.onrender.com

# URL de la API de imágenes (perfil, etc.)
# Producción: https://api-imagenes-healthymind.onrender.com
VITE_IMAGES_API_URL=https://api-imagenes-healthymind.onrender.com
